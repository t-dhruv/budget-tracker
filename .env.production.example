# ────────────────────────────────────────────────────────────────────────
# Budget Tracker – Self-host production env example
#
# Copy this file to .env.production at the repo root, then fill in the
# REQUIRED section.
#
# This file stays ON THE VPS. The compose file reads it via `--env-file`
# (build-time interpolation for VITE_* args) and `env_file:` (runtime
# backend env). It is NEVER copied into a Docker image – DB password and
# auth secrets stay out of pushed image layers.
#
# Frontend (VITE_*) values are inlined at Docker BUILD time, so any change
# to them needs `docker compose build frontend` afterwards.
# ────────────────────────────────────────────────────────────────────────

# === REQUIRED – boot fails without these ================================

NODE_ENV=production

# --- Public URL (the Cloudflare Tunnel public hostname) ---
# This is your Cloudflare Tunnel's public hostname, e.g. budget.example.com
# or a Cloudflare Workers.dev subdomain. Used by the backend to generate
# OAuth callbacks and auth URLs. Must match what Cloudflare Tunnel points
# to on the frontend.
BETTER_AUTH_URL=https://budget.example.com
AUTH_ORIGIN=https://budget.example.com

# --- Auth secrets – generate with: openssl rand -base64 32 ---
APPLICATION_JWT_SECRET=__REPLACE_ME__
APP_SESSION_ID_SECRET=__REPLACE_ME__
BETTER_AUTH_SECRET=__REPLACE_ME__

# --- Database ---
APPLICATION_DB_HOST=db
APPLICATION_DB_PORT=5432
APPLICATION_DB_USERNAME=budget_tracker
APPLICATION_DB_PASSWORD=__REPLACE_ME__
APPLICATION_DB_DATABASE=budget_tracker
APPLICATION_DB_DIALECT=postgres

# --- Redis ---
APPLICATION_REDIS_HOST=redis

# --- Backend bind ---
APPLICATION_HOST=0.0.0.0
APPLICATION_PORT=24681

# --- Frontend build-time (inlined into the JS bundle) ---
# API calls now go through the frontend nginx reverse proxy (same origin).
# Leave empty — the SPA uses relative URLs (/api/v1/...) which the nginx
# proxy forwards to the backend. Only set a full URL if you bypass the
# proxy and expose the backend directly (not recommended).
VITE_APP_API_HTTP=
VITE_APP_API_VER=/api/v1

# === OPTIONAL – features off until set ==================================

# --- Email (transactional / verification). Without RESEND_API_KEY email
# verification is disabled and users can register with any address. ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev

# --- OAuth providers (both pairs are independent – set one or both). ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Bank linking via Enable Banking. Must be https://<frontend>/bank-callback ---
# ENABLE_BANKING_REDIRECT_URL=https://budget.example.com/bank-callback

# --- Investments / market data (set one or more) ---
# POLYGON_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# FMP_API_KEY=
# COINGECKO_API_KEY=
# CRYPTO_PRICES_SYNC_INTERVAL_MINUTES=15

# --- Currency rates ---
# API_LAYER_API_KEYS=

# --- AI transaction categorisation (set one) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=

# --- Brand logos (logo.dev) ---
# VITE_LOGO_DEV_TOKEN=
# LOGO_DEV_SECRET_KEY=

# --- Observability (all optional) ---
# SENTRY_DSN=
# VITE_SENTRY_DSN=
# POSTHOG_KEY=
# POSTHOG_HOST=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=

# --- Admins (comma-separated usernames) ---
# ADMIN_USERS=

# --- Passkeys / WebAuthn ---
# AUTH_RP_ID defaults to "localhost"; set to your bare domain (no scheme)
# for passkey support.
# AUTH_RP_ID=example.com
# AUTH_RP_NAME=Budget Tracker

# --- Extra CORS origins (comma-separated, beyond AUTH_ORIGIN) ---
# ALLOWED_ORIGINS=

# === ADVANCED ===========================================================

# Extra CSP connect-src hosts for PostHog / Sentry. Leave empty if you
# don't run analytics – keeps the CSP minimal.
# CSP_EXTRA_ANALYTICS=https://*.i.posthog.com https://*.sentry.io

# Disable all background exchange-rate fetch jobs
# OFFLINE_MODE=false

# Disable Yahoo Finance as an investments data source
# YAHOO_FINANCE_ENABLED=true

# Backend SQL query logging
# DB_QUERY_LOGGING=false

# --- Port overrides ---
# DB_HOST_PORT=5432
# REDIS_HOST_PORT=6379
