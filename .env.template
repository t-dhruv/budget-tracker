NODE_ENV=development

APPLICATION_HOST=127.0.0.1
APPLICATION_PORT=24681
APPLICATION_JWT_SECRET=jwt-secret

APPLICATION_DB_HOST=db
APPLICATION_DB_PORT=5432
APPLICATION_DB_USERNAME=username
APPLICATION_DB_PASSWORD=password
APPLICATION_DB_DATABASE=budget-tracker
APPLICATION_DB_DIALECT=postgres

# Automated database backup (sidecar container)
BACKUP_RETENTION_DAYS=30
# BACKUP_SCHEDULE=0 4 * * *  # Default: daily at 4 AM

APPLICATION_REDIS_HOST=redis
# Custom port that Docker compose will map Redis to, for local development
MAP_REDIS_PORT_TO_OS_PORT=6380

# Redis Commander port mapping
MAP_REDIS_COMMANDER_PORT_TO_OS_PORT=24683

# Set to 'true' to enable SQL query logging in console (useful for debugging)
DB_QUERY_LOGGING=false
I18N_LOGGING=false

# Define what origins are allowed by backend to avoid CORS
ALLOWED_ORIGINS=http://localhost:8100,https://localhost:8100,http://127.0.0.1:8100,https://127.0.0.1:8100

APP_SESSION_ID_SECRET=development

# For AI features, like automatic categorization
GEMINI_API_KEY=
NVIDIA_API_KEY= # Sign up at https://build.nvidia.com/ to get a free API key for the NVIDIA API Catalog

# Investments functionality
# Needed for investments functionality, to load info about securities, prices, etc
POLYGON_API_KEY= # Can be obtained at https://massive.com/ (previously polygon.io)
ALPHA_VANTAGE_API_KEY= # Can be obtained at https://www.alphavantage.co/
FMP_API_KEY= # Can be obtained at https://site.financialmodelingprep.com/
COINGECKO_API_KEY= # CoinGecko Demo API key for crypto price data. Sign up at https://www.coingecko.com/en/api/pricing (Demo tier is free)
LOGO_DEV_SECRET_KEY= # logo.dev secret key for payee brand-logo search (server-side only). Sign up at https://logo.dev
CRYPTO_PRICES_SYNC_INTERVAL_MINUTES=15 # Crypto price sync cadence in minutes (integer 1–59). Default: 15.

# Currency exchange rates (optional)
# Sign up at https://marketplace.apilayer.com/fixer-api. Free tier is 100 requests/month,
# so list several keys comma-separated to round-robin (e.g. abc123,def456).
# Leave empty to disable – the app falls back to Frankfurter (free, no key needed).
API_LAYER_API_KEYS=

# Keep as is
CURRENCY_RATES_API_URL=http://currency-rates-api:8080

# Enable Banking configuration
# Redirect URL for OAuth flow (must match the URL registered in Enable Banking portal)
ENABLE_BANKING_REDIRECT_URL=https://localhost:8100/bank-callback

# e2e tests are running in parallel. To achieve that, we need to define a strict
# amount of workers, so that the same amount of DBs will be created to avoid collisions
JEST_WORKERS_AMOUNT=4

# pgAdmin config
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=password
PGADMIN_LISTEN_PORT=24682

# Logging with Grafana Loki (optional). Leave empty to disable.
# Host format: https://<your_prefix>.grafana.net
GRAFANA_LOKI_HOST=
GRAFANA_LOKI_AUTH=
GRAFANA_LOKI_USER_ID=

###############
# Frontend envs
###############

HOST=localhost
PORT=8100
VITE_APP_API_HTTP=http://127.0.0.1:24681 # same port as APPLICATION_PORT
VITE_APP_API_VER=/api/v1

# Brand logos for subscriptions, banks, and stock tickers via logo.dev.
# Publishable key – safe to inline into the frontend bundle. Get a free
# token at https://www.logo.dev. Leave empty to fall back to initials.
VITE_LOGO_DEV_TOKEN=

# Comma-separated. These users (usernames) are able to trigger special events
# like data sync and have special access
ADMIN_USERS=test-user-1,test-user-2

# Better Auth Core (REQUIRED)
# Secret used to sign sessions/tokens. The value below works for local dev only.
# For production, generate a fresh 32+ char random secret (e.g. `openssl rand -base64 48`).
BETTER_AUTH_SECRET=development-secret-change-in-production-min-32-chars
BETTER_AUTH_URL=https://localhost:8100

# Passkey/WebAuthn Configuration (REQUIRED for passkeys)
AUTH_RP_ID=localhost # For production use {domain.com}
AUTH_ORIGIN=https://localhost:8100 # Full URL with protocol. Must match where the frontend is served from
AUTH_RP_NAME=MoneyMatter

# Google OAuth (optional – leave empty to hide the "Sign in with Google" button)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional – leave empty to hide the "Sign in with GitHub" button)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email verification via Resend (optional – leave empty to disable email verification)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev # Must be verified in Resend, or use onboarding@resend.dev for testing
